Procedure bk_bm;

  var NextChar:integer;
  var n:integer;

  begin
  ht_DRef.Value:=0;

  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then
    begin
    if NextChar=AsciiCode.BigB then {bmb}
      Axis[ht_DRef.AxisNumber].BeginMoveBy(NextDouble)

    else if NextChar=AsciiCode.BigT then {bmt}
      Axis[ht_DRef.AxisNumber].BeginMoveTo(NextDouble);
    end

  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);
    if NextChar=AsciiCode.BigB then {relative move}
      begin
      if n=2 then
        T2[ht_DRef.AxisNumber].BeginMoveBy(NextDouble,NextDouble)
      else if n=3 then
        T3[ht_Dref.AxisNumber].BeginmoveBy(
          NextDouble,NextDouble,NextDouble)
{$IFDEF MoreThan3Axes}
      else if n=4 then
        T4[ht_Dref.AxisNumber].BeginmoveBy(
          NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=5 then
        T5[ht_DRef.AxisNumber].BeginMoveBy(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=6 then
        T6[ht_Dref.AxisNumber].BeginMoveBy(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else if NextChar=AsciiCode.BigC then
      begin
      if n=2 then
        T2[ht_DRef.AxisNumber].BeginMoveAlongCurve
      else if n=3 then
        T3[ht_Dref.AxisNumber].BeginMoveAlongCurve
{$IFDEF MoreThan3Axes}
      else if n=4 then
        T4[ht_Dref.AxisNumber].BeginMoveAlongCurve
      else if n=5 then
        T5[ht_DRef.AxisNumber].BeginMoveAlongCurve
      else if n=6 then
        T6[ht_Dref.AxisNumber].BeginMoveAlongCurve
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else if NextChar=AsciiCode.BigT then {absolute move}
      begin
      if n=2 then
        begin
        T2[ht_DRef.AxisNumber].BeginMoveTo(
          NextDouble,NextDouble);
        end
      else if n=3 then
        T3[ht_Dref.AxisNumber].BeginMoveTo(
          NextDouble,NextDouble,NextDouble)
{$IFDEF MoreThan3Axes}
      else if n=4 then
        T4[ht_Dref.AxisNumber].BeginMoveTo(
          NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=5 then
        T5[ht_DRef.AxisNumber].BeginMoveTo(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=6 then
        T6[ht_Dref.AxisNumber].BeginMoveTo(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else
      GrammarError;
    end

  else
    GrammarError;
  end;
TRUE
