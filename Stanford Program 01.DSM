{$IFDEF MoreThan3Axes}
      else if n=4 then
        begin
        try
          T4[ht_DRef.AxisNumber].SetCommandedPosition(
            NextDouble,
            NextDouble,
            NextDouble,
            NextDouble)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T4[ht_DRef.AxisNumber].CommandedPosition;
        end

      else if n=5 then
        begin
        try
          T5[ht_DRef.AxisNumber].SetCommandedPosition(
            NextDouble,
            NextDouble,
            NextDouble,
            NextDouble,
            NextDouble)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T5[ht_DRef.AxisNumber].CommandedPosition;
        end


      else if n=6 then
        begin
        try
          T6[ht_DRef.AxisNumber].SetCommandedPosition(
            NextDouble,
            NextDouble,
            NextDouble,
            NextDouble,
            NextDouble,
            NextDouble)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T6[ht_DRef.AxisNumber].CommandedPosition;
        end
{$ENDIF}

      else
        Escape(Error.IllegalDimension);
      end

