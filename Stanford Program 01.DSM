14
procedure ByteToHexStringWithSpace(Value:integer);

  var HighDigit:integer;
  var LowDigit:integer;

  begin  
  Value:=Value and $FF;
  HighDigit:=Value div $10;
  LowDigit:=Value and $F;
  StringAtPut(HexString,0,HexValueToCharacter(HighDigit));
  StringatPut(HexString,1,HexValueToCharacter(LowDigit));
  StringatPut(HexString,2,32);
  StringAtPut(HexString,3,0);
  end;
TRUE
