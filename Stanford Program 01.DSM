81
Procedure bk_cp;

  var NextChar:integer;
  var n:integer;
  var Valid:boolean;
  var Param:longint;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then
    begin
    if NextChar=AsciiCode.BigU then
      begin
      try
        Axis[ht_DRef.AxisNumber].SetCountsPerUserUnit(NextDouble)
      recover
        ConfirmNoExpression;
      ht_Dref.Value:=Axis[ht_Dref.AxisNumber].CountsPerUserUnit;
      end
    else
      GrammarError;
    end

  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);
    if NextChar=AsciiCode.BigU then {relative move}
      begin
      if n=2 then
        begin
        try
          T2[ht_DRef.AxisNumber].SetCountsPerUserUnit(NextDouble)
        recover
          ConfirmNoExpression;
        ht_Dref.Value:=T2[ht_Dref.AxisNumber].CountsPerUserUnit;
        end
      else if n=3 then
        begin
        try
          T3[ht_DRef.AxisNumber].SetCountsPerUserUnit(NextDouble)
        recover
          ConfirmNoExpression;
        ht_Dref.Value:=T3[ht_Dref.AxisNumber].CountsPerUserUnit;
        end
{$IFDEF MoreThan3Axes}
      else if n=4 then
        begin
        try
          T4[ht_DRef.AxisNumber].SetCountsPerUserUnit(NextDouble)
        recover
          ConfirmNoExpression;
        ht_Dref.Value:=T4[ht_Dref.AxisNumber].CountsPerUserUnit;
        end
      else if n=5 then
        begin
        try
          T5[ht_DRef.AxisNumber].SetCountsPerUserUnit(NextDouble)
        recover
          ConfirmNoExpression;
        ht_Dref.Value:=T5[ht_Dref.AxisNumber].CountsPerUserUnit;
        end
      else if n=6 then
        begin
        try
          T6[ht_DRef.AxisNumber].SetCountsPerUserUnit(NextDouble)
        recover
          ConfirmNoExpression;
        ht_Dref.Value:=T6[ht_Dref.AxisNumber].CountsPerUserUnit;
        end
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else
      GrammarError
    end
  else
    GrammarError;
  end;
TRUE
