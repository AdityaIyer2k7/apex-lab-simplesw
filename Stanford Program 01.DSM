var AsciiCode:Object
    const BigA=65;
    const BigB=66;
    const BigC=67;
    const BigD=68;
    const BigE=69;
    const BigF=70;
    const BigG=71;
    const BigH=72;
    const BigI=73;
    const BigJ=74;
    const BigK=75;
    const BigL=76;
    const BigM=77;
    const BigN=78;
