80
Procedure bk_dl;

  var NextChar:integer;
  var n:integer;
  var StartOffset:longint;
  var Offset:longint;
  var DoneWithDownload:boolean;
  var NewByte:integer;
  var ErrorCounter:longint;
  var HiNibble:integer;
  var LowNibble:integer;
  var scanner:longint;
  var AutostartAddress:longint;
  var CompareCheck:boolean;

  begin
 { CompareCheck:=false;
  NextChar:=StringAt(InspectToken.Value,2);
  Match(tk_Word);

  if NextChar=AsciiCode.BigD then    
    begin
    StartOffset:=NextLong;
    AutostartAddress:=NextLong+$20000000;
    Offset:=StartOffset;
    DoneWithDownload:=false;
    ErrorCounter:=0;
    repeat
      while not Comm.CharacterPresent do
        yield;
      while Comm.CharacterPresent do
        begin
        NextChar:=Comm.GetCharacter;
        if NextChar=37 then
          DoneWithDownload:=true
        else if (NextChar=32) or (NextChar=13) or (NextChar=10) then
          begin

          end
        else
          begin
          HiNibble:=CharToHex(NextChar);
          while not Comm.CharacterPresent do
            yield;
          NextChar:=Comm.GetCharacter;
          LowNibble:=CharToHex(NextChar);
          NewByte:=HiNibble*16+LowNibble;
          if CompareCheck then
            begin
            if (Server.MemReadByte($2000,Offset) and $FF) <> NewByte then
              begin
              Prompter.writeln('Current: ',Server.MemReadByte($2000,Offset),' ',NewByte);
              ErrorCounter:=ErrorCounter+1;
              end;
            end
          else
            Server.MemWriteByte($3000,Offset,NewByte);
          Offset:=Offset+1;
          end;
        end;
    until DoneWithDownload;    
      
    if not FlashMemory.IsErased then           
      FlashMemory.Erase       
    FlashMemory.WriteHeader(AutostartAddress); 
    FlashMemory.FlashReset;
  
    for scanner:=$20 to StartOffset do      
      FlashMemory.ProgramByte($8000,scanner,Server.MemReadByte($2000,scanner));          

    for scanner:=StartOffset+1 to $FFFF do
      FlashMemory.ProgramByte($8000,scanner,Server.MemReadByte($3000,scanner));

    FlashMemory.FlashReset;   
    ht_Dref.Value:=1;
    end
  else
    GrammarError;}
  end;

TRUE
