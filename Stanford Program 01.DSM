49
Procedure bk_ab;

  var NextChar:integer;
  var n:integer;
  var Valid:boolean;
  var Param:longint;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then   
    begin
    if NextChar=AsciiCode.BigT then
      begin {ABT}      
      Axis[ht_DRef.AxisNumber].Abort;
      ht_DRef.Value:=1;
      end
    else
      GrammarError;
    end

  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);    
    ht_DRef.Value:=n;
    if NextChar=AsciiCode.BigT then 
      begin
      if n=2 then            
        T2[ht_DRef.AxisNumber].Abort        
      else if n=3 then
        T3[ht_DRef.AxisNumber].Abort 
{$IFDEF MoreThan3Axes}       
      else if n=4 then
        T4[ht_DRef.AxisNumber].Abort        
      else if n=5 then
        T5[ht_DRef.AxisNumber].Abort
      else if n=6 then
        T6[ht_DRef.AxisNumber].Abort
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else
      GrammarError;
    end
  else
    GrammarError;
  end;
TRUE
TUserProcedure
0 {reference}
FALSE
142
Procedure bk_ac;

  var NextChar:integer;
  var n:integer;
  var Valid:boolean;
  var Param:longint;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then   
    begin
    if NextChar=AsciiCode.BigL then
      begin {ACL}
      try                
        Axis[ht_DRef.AxisNumber].SetAccel(NextSingle)
      recover
        ConfirmNoExpression;      
      ht_DRef.Value:=Axis[ht_DRef.AxisNumber].Accel
      end
    else if NextChar=AsciiCode.BigP then
      begin {ACP}
      try                
        Axis[ht_DRef.AxisNumber].SetActualPosition(NextDouble)
      recover
        ConfirmNoExpression;      
      ht_DRef.Value:=Axis[ht_DRef.AxisNumber].ActualPosition
      end
    else if NextChar=AsciiCode.BigT then
      begin {AIC}
      Axis[ht_DRef.AxisNumber].ArmCapture;
      ht_DRef.Value:=1;
      end
    else
      GrammarError;
    end

  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);    
    if NextChar=AsciiCode.BigL then 
      begin
      if n=2 then
        begin
        try
          T2[ht_DRef.AxisNumber].SetAccel(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T2[ht_DRef.AxisNumber].Accel
        end

      else if n=3 then
        begin
        try
          T3[ht_DRef.AxisNumber].SetAccel(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T3[ht_DRef.AxisNumber].Accel
        end

{$IFDEF MoreThan3Axes}
      else if n=4 then
        begin
        try
          T4[ht_DRef.AxisNumber].SetAccel(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T4[ht_DRef.AxisNumber].Accel
        end

      else if n=5 then
        begin
        try
          T5[ht_DRef.AxisNumber].SetAccel(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T5[ht_DRef.AxisNumber].Accel
        end

      else if n=6 then
        begin
        try
          T6[ht_DRef.AxisNumber].SetAccel(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T6[ht_DRef.AxisNumber].Accel
        end
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end

    else if NextChar=AsciiCode.BigP then 
      begin      
      if n=2 then            
        T2[ht_DRef.AxisNumber].SetActualPosition(
          NextDouble,
          NextDouble)                 

      else if n=3 then
        T3[ht_DRef.AxisNumber].SetActualPosition(
          NextDouble,
          NextDouble,
          NextDouble)        

{$IFDEF MoreThan3Axes}
      else if n=4 then
        T4[ht_DRef.AxisNumber].SetActualPosition(
          NextDouble,
          NextDouble,
          NextDouble,
          NextDouble)

      else if n=5 then
        T5[ht_DRef.AxisNumber].SetActualPosition(
          NextDouble,
          NextDouble,
          NextDouble,
          NextDouble,
          NextDouble)

      else if n=6 then
        T6[ht_DRef.AxisNumber].SetActualPosition(
          NextDouble,
          NextDouble,
          NextDouble,
          NextDouble,
          NextDouble,
          NextDouble)
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end

    else
      GrammarError;
    end

  else
    GrammarError;
  end;
TRUE
TUserProcedure
0 {reference}
FALSE
