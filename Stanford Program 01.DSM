Function CharTohex(Value:integer):integer;
  begin
  if (Value>=48) and (Value <=57) then
    CharToHex:=Value-48
  else if (Value>=65) and (Value<=70) then
    CharToHex:=Value-55
  else
    Escape(Error.Assertion);
  end;
