Procedure bk_ln;

  var NextChar:integer;
  var BufferNumber:integer;
  var n:integer;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_TNAxis then   
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);        
    BufferNumber:=GetNextCurveBufferNumber;
    if BufferNumber=0 then
      Escape(Error.OutOfCurveBuffers);
    ht_DRef.Value:=BufferNumber;
    if NextChar=AsciiCode.BigK then
      begin 
      if n=2 then
        begin
        if BufferNumber=1 then
          T2[ht_DRef.AxisNumber].LinkTo(CurveBuffer1)
        else
          T2[ht_DRef.AxisNumber].LinkTo(CurveBuffer2);
        end
      else
        Escape(Error.IllegalDimension)
      end
    else
      GrammarError;
    end

  else
    GrammarError;
  end;
