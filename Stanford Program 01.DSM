17
Function GetCharacter:longint;

  var TimeoutCounter:longint;

  begin
  TimeoutCounter:=0;
  while Head=Tail do
    begin
    yield;
    TimeoutCounter:=TimeoutCounter+1;
    if timeoutCounter > 1000 then
      Escape(600);
    end;

  GetCharacter:=Fifo[Tail];
  Tail:=(Tail+1) and FifoSize;
  end;
