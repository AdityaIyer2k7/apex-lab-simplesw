procedure Assign_IP_Address_and_Port(IP3:integer; IP2:integer; IP1:integer; IP0:integer; Port:integer);  
  begin
  EthernetSetLongintIPAddress(
    IPAddressToLongint(IP3,IP2,IP1,IP0),
    IPAddressToLongint(255,255,255,0),
    IPAddressToLongint(IP3,IP2,IP1,250));
	BeginTask(TaskAddr(MaintainEthernetPolling));

  EthernetSocketInitialize(PortHandle,Port);
	PeekPresent:=false;
  end;
TRUE
TUserFunction
10 {reference}
TRUE
16
function CharacterPresent:boolean;
  begin
	if PeekPresent then
	  CharacterPresent:=true
	else
	  begin
	  PeekCharacter:=EthernetGetData(PortHandle);
		if PeekCharacter=-1 then
		  CharacterPresent:=false
		else
		  begin
			CharacterPresent:=true;
			PeekPresent:=true;
			end;
		end;
  end;
TRUE
TUserFunction
11 {reference}
TRUE
18
function GetCharacter:longint;

  var Value:longint;

  begin
	if PeekPresent then
	  begin
		GetCharacter:=PeekCharacter and $FF;
		PeekPresent:=false;
		end
	else
	  begin
    Value:=EthernetGetData(PortHandle);
    if Value=-1 then
      Escape(ec_DataNotPresent);
    GetCharacter:=Value and $FF
		end;
  end;
