Function IndexAtName(var aName:string):integer;

  var scanner:integer;

  begin
  for scanner:=1 to MaxNamedProcedures do
    begin
    if (scanner and 15)=0 then 
      yield;
    if ProcedureName[scanner]=aName then
      begin
      IndexAtName:=scanner;
      exit;
      end;
    end;
  Escape(Error.UnableToFindNamedProcedure);
  end;
TRUE
