Function ArrayIndexExpression:integer;
  begin
  if InspectToken.Kind=tk_Literal then
    begin
    ArrayIndexExpression:=LongintInString(InspectToken.Value);
    Match(tk_Literal);
    end
  else
    Escape(7000);
  end;
