Procedure SendString(var aString:string);

  var scanner:longint;
  var char:longint;

  begin
  scanner:=0;
  repeat  
    Char:=StringAt(aString,scanner);
    if Char <> 0 then
      SendCharacter(Char);
    scanner:=scanner+1;
  until Char=0;
  end;
