  var BooleanParam:boolean;
  var Index:longint;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then   
    begin
    if NextChar=AsciiCode.BigV then
      begin 
      try                
        Axis[ht_DRef.AxisNumber].SetCoordinateInversion(NextBoolean)
      recover
        ConfirmNoExpression;      
      ht_DRef.Value:=BooleanToInteger(Axis[ht_DRef.AxisNumber].CoordinateInversionIsOn);
      end
    else
      GrammarError;
    end

  else if NextChar=AsciiCode.BigO then
    begin
    Index:=IntegerConfineBetween(NextLong,1,12,ParameterOutOfRangeEscapeCode);
    BooleanParam:=NextBoolean;
    ConfigureIoBitAsOutput(Index,BooleanParam);
    ht_DRef.Value:=BooleanToInteger(BooleanParam);
    end

  else
    GrammarError;
  end;
