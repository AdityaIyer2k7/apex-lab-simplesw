      Match(tk_Word);      
      for scanner:=1 to ProcedureParamCount[CallIndex] do
        Param[scanner]:=NextSingle;      
      ExecuteTask(ProcedureAddress[CallIndex]);      
      ht_DRef.Value:=ReturnValue;
      end
    else
      GrammarError;
    end

