20
Procedure bk_rw;

  var NextChar:integer;
  var n:integer;
  var FoundTripped:boolean;

  begin
  NextChar:=StringAt(InspectToken.Value,2);
  Match(tk_Word);

  if NextChar=AsciiCode.BigD then
    begin
    FoundTripped:=WatchdogHasTripped;
    ResetWatchDog;
    ht_DRef.Value:=BooleanToInteger(FoundTripped);
    end
  else
    GrammarError;
  end;

