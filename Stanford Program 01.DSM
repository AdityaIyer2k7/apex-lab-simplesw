61
Procedure DoubleToString(Value:double; NumberOfDecimalPlaces:integer; var Result:string);
{version 3 , July 28}
  var OffsetFactor:longint;
  var Digit:longint;
  var Index:integer;    
  const MinusSign=45;
  const DecimalPoint=46;
  var DigitHasBeenFound:boolean;
  var Divisor:longint;
  var LongintValue:longint;
  var scanner:integer;
  var Anchor:longint;

  begin
  OffsetFactor:=1;
  for scanner:=1 to NumberOfDecimalPlaces do
    OffsetFactor:=OffsetFactor*10;

  LongintValue:=round(OffsetFactor*Value);

  Index:=0; 
  
  if LongintValue < 0 then
    begin    
    LongintValue:=abs(LongintValue);
    StringAtPut(Result,Index,MinusSign);
    Index:=Index+1;
    end 

  DigitHasBeenFound:=false;
  if abs(Value) < 1 then
    begin
    Divisor:=OffsetFactor*10;
    DigitHasBeenFound:=true
    end
  else
    begin
    Divisor:=10;
    while Divisor <= LongintValue do
      Divisor:=Divisor*100;
    end;

  repeat
    Divisor:=Divisor div 10;
    Digit:=LongintValue div Divisor
    if (Digit > 0) or (Divisor=1) or DigitHasBeenFound then
      begin    
      StringAtPut(Result,Index,Digit+48);
      Index:=Index+1;
      LongintValue:=LongintValue-(Digit*Divisor);    
      DigitHasBeenFound:=true;
      end;
    if Divisor=OffsetFactor then
      begin
      StringatPut(Result,Index,DecimalPoint);
      Index:=Index+1;
      end;
  until Divisor=1;

  StringAtPut(Result,Index,0);
  end;
TRUE
