Procedure bk_al;

  var NextChar:integer;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if NextChar=AsciiCode.BigI then
    begin {ALI}      
    ht_DRef.Value:=AnalogInput(NextLong);
    end
  else
    GrammarError;
  end;

