73
Procedure bk_am;

  var NextChar:integer;
  var n:integer;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then   
    begin
    ht_DRef.Value:=NextSingle;
    if NextChar=AsciiCode.BigP then {current setting}
      SetCurrent(Axis[ht_DRef.AxisNumber],ht_DRef.Value)
    else
      GrammarError;
    end

  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);    
    ht_DRef.Value:=n;
    if NextChar=AsciiCode.BigB then {relative move}
      begin
      if n=2 then
        T2[ht_DRef.AxisNumber].AppendMoveBy(
          NextDouble,NextDouble)
      else if n=3 then
        T3[ht_Dref.AxisNumber].AppendMoveBy(
          NextDouble,NextDouble,NextDouble)
{$IFDEF MoreThan3Axes}
      else if n=4 then
        T4[ht_Dref.AxisNumber].AppendMoveBy(
          NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=5 then
        T5[ht_DRef.AxisNumber].AppendMoveBy(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=6 then
        T6[ht_Dref.AxisNumber].AppendMoveBy(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else if NextChar=AsciiCode.BigT then {absolute move}
      begin
      if n=2 then
        T2[ht_DRef.AxisNumber].AppendMoveTo(
          NextDouble,NextDouble)
      else if n=3 then
        T3[ht_Dref.AxisNumber].AppendMoveTo(
          NextDouble,NextDouble,NextDouble)
{$IFDEF MoreThan3Axes}
      else if n=4 then
        T4[ht_Dref.AxisNumber].AppendMoveTo(
          NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=5 then
        T5[ht_DRef.AxisNumber].AppendMoveTo(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=6 then
        T6[ht_Dref.AxisNumber].AppendMoveTo(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else
      GrammarError;
    end

  else
    GrammarError;
  end;
TRUE
