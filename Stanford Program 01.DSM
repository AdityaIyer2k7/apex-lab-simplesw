Procedure bk_ei;

  var NextChar:integer;
  var Parameter:boolean;
 
  begin
{$IFDEF Closed_Loop}
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then   
    begin
    if NextChar=AsciiCode.BigV then
      begin 
      Parameter:=NextBoolean;
      Closed_Loop.Set_Encoder_Inversion(Axis[ht_DRef.AxisNumber],Parameter)
      ht_DRef.Value:=BooleanToInteger(Parameter);
      end
    else
      GrammarError;
    end

  else
{$ENDIF}
    GrammarError;
  end;
