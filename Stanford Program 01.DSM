0 {reference}
FALSE
53
Function DoubleInString(var NumberString:string):double;
{----------------------------------------------------------}

  var scanner:longint;
  var accumulator:double;
  var IsNegative:boolean;
  var NewPart:longint;
  var Divisor:longint;
  var DecimalPointFound:boolean;

  begin
  DecimalPointFound:=false;
  scanner:=0;
  while StringAt(NumberString,scanner)=32 {space} do
    scanner:=scanner+1;

  if StringAt(NumberString,scanner)=45 {minus sign} then
    begin
    IsNegative:=true
    scanner:=scanner+1;
    end
  else
    IsNegative:=false;

  Accumulator:=0;
  Divisor:=1;
  while StringAt(NumberString,scanner) <> 0 do
    begin
    if StringAt(NumberString,scanner)=46 then
      begin
      DecimalPointFound:=true;
      scanner:=scanner+1;
      end
    else
      begin
      NewPart:=StringAt(NumberString,scanner)-48; {ascii code zero}
      yield;
      if not DecimalPointFound then
        Accumulator:=Accumulator*10+NewPart
      else
        begin
        Divisor:=Divisor*10;
        Accumulator:=Accumulator+(NewPart/Divisor);
        end;
      scanner:=scanner+1;
      end;  
    end;

  if IsNegative then
    DoubleInString:=-Accumulator
  else
    DoubleInString:=Accumulator;
  end; 
TRUE
TUserProcedure
0 {reference}
FALSE
25
Function GetNextCurveBufferNumber:integer;

  var GroupScanner:integer;
  var CurveNumberScanner:integer;
  var CurveNumberAlreadyUsed:boolean;

  begin
  for CurveNumberScanner:=1 to 2 do
    begin
    CurveNumberAlreadyUsed:=false;
    for GroupScanner:=1 to MaxGroupNumber do
      begin
      if TimeRemaining < 400 then
        yield;
      if CurveBufferNumberForGroup[GroupScanner]=CurveNumberScanner then
        CurveNumberAlreadyUsed:=true;
      end;
    if not CurveNumberAlreadyUsed then
      begin
      GetNextCurveBufferNumber:=CurveNumberScanner;
      exit;
      end;
    end;    
  GetNextCurveBufferNumber:=0; {no curve buffers available}
  end;
TRUE
TUserProcedure
0 {reference}
FALSE
14
function GroupDimension(CandidateGroupNumber:integer):integer;

  var GroupNumber:integer;

  begin
  GroupNumber:=IntegerConfineBetween(
    CandidateGroupNumber,1,MaxGroupNumber,Error.GroupNumberOutOfBounds);

  if GroupInitialized[GroupNumber]=0 then    
    Escape(Error.GroupNotInitialized);

  GroupDimension:=GroupDimensionArray[GroupNumber];
  end;

TRUE
TUserProcedure
0 {reference}
FALSE
11
Function HashIndexOfString(var aString:string):integer;

  var FirstChar:integer;
  var SecondChar:integer;

  begin
  FirstChar:=IntegerConfineBetween(StringAt(aString,0)-AsciiCode.BigA,0,25,Error.Grammar);
  SecondChar:=IntegerConfineBetween(StringAt(aString,1)-AsciiCode.BigA,0,25,Error.Grammar);

  HashIndexOfString:=IntegerConfineBetween((FirstChar*26)+SecondChar,0,676,Error.Assertion);
  end;
TRUE
TUserProcedure
0 {reference}
FALSE
15
Function HexValueToCharacter(Value:integer):integer;
  begin
  try
    Value:=IntegerConfineBetween(Value,0,15,Error.Assertion)
  recover
    begin
    prompter.writeln('Value: ',value);
    Value:=0;
    end;

  if (Value >=0) and (Value <=9) then  
    HexValueToCharacter:=Value+48
  else
    HexValueToCharacter:=Value+55
  end;
