35
procedure LongintToNumberString(aNumber:longint);
{-----------------------------------------------------------------------------------------}

  var Digit:longint;
  var Index:integer;    
  const MinusSign=45;
  var DigitHasBeenFound:boolean;
  var Divisor:longint;

  begin
  Index:=0; 
  
  if aNumber < 0 then
    begin    
    aNumber:=abs(aNumber);
    StringAtPut(NumberString,Index,MinusSign);
    Index:=Index+1;
    end 

  Divisor:=1000000000;
  DigitHasBeenFound:=false;
  repeat
    Divisor:=Divisor div 10;
    Digit:=aNumber div Divisor
    if (Digit > 0) or (Divisor=1) or DigitHasBeenFound then
      begin    
      StringAtPut(NumberString,Index,Digit+48);
      Index:=Index+1;
      aNumber:=aNumber-(Digit*Divisor);    
      DigitHasBeenFound:=true;
      end;
  until Divisor=1;

  StringAtPut(NumberString,Index,0);
  end;
TRUE
