31
Function LongintInString(var NumberString:string):longint;
{----------------------------------------------------------}

  var scanner:longint;
  var accumulator:longint;
  var IsNegative:boolean;

  begin
  if StringAt(NumberString,0)=AsciiCode.MinusSign then
    begin
    IsNegative:=true;
    scanner:=1;
    end
  else
    begin
    IsNegative:=false;
    scanner:=0;  
    end;

  Accumulator:=0;
  while StringAt(NumberString,scanner) <> 0 do
    begin
    Accumulator:=Accumulator*10+StringAt(NumberString,scanner)-AsciiCode.Zero;     
    scanner:=scanner+1;
    end;  

  if IsNegative then
    LongintInString:=-Accumulator
  else
    LongintInString:=Accumulator;
  end;
TRUE
TUserProcedure
