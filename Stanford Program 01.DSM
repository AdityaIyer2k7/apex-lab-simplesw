  else if NextChar=AsciiCode.BigP then
    begin
    if ht_DRef.AxisTokenKind=tk_T1Axis then
      begin
      BooleanParam:=NextBoolean;
      Closed_Loop.Set_Closed_Loop(Axis[ht_Dref.AxisNumber],BooleanParam);
      ht_Dref.Value:=BooleanToInteger(BooleanParam);
      end
    else
      GrammarError
    end
{$ENDIF}

  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);    
    ht_DRef.Value:=n;
    if NextChar=AsciiCode.BigR then
      begin
      if n=2 then
        T2[ht_DRef.AxisNumber].Clear
      else if n=3 then
        T3[ht_Dref.AxisNumber].Clear
{$IFDEF MoreThan3Axes}
      else if n=4 then
        T4[ht_Dref.AxisNumber].Clear
      else if n=5 then
        T5[ht_DRef.AxisNumber].Clear
      else if n=6 then
        T6[ht_Dref.AxisNumber].Clear
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else
      GrammarError;
    end

  else
    GrammarError;
