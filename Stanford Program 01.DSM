76
Procedure bk_pf;

  var NextChar:integer;
  var n:integer;
  var Valid:boolean;
  var Param:longint;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then
    begin
    if NextChar=AsciiCode.BigP then {ProFilePhase}
      ht_DRef.Value:=Axis[ht_DRef.AxisNumber].ProfilePhase

    else if NextChar=AsciiCode.BigV then {ProFileVelocity}
      ht_DRef.Value:=Axis[ht_DRef.AxisNumber].ProfileVelocity

    else
      GrammarError;
    end

  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);
    if NextChar=AsciiCode.BigP then
      begin
      if n=2 then
        ht_DRef.Value:=T2[ht_DRef.AxisNumber].ProfilePhase

      else if n=3 then
        ht_DRef.Value:=T3[ht_DRef.AxisNumber].ProfilePhase

{$IFDEF MoreThan3Axes}
      else if n=4 then
        ht_DRef.Value:=T4[ht_DRef.AxisNumber].ProfilePhase

      else if n=5 then
        ht_DRef.Value:=T5[ht_DRef.AxisNumber].ProfilePhase

      else if n=6 then
        ht_DRef.Value:=T6[ht_DRef.AxisNumber].ProfilePhase
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end

    else if NextChar=AsciiCode.BigV then
      begin
      if n=2 then
        ht_DRef.Value:=T2[ht_DRef.AxisNumber].ProfileVelocity

      else if n=3 then
        ht_DRef.Value:=T3[ht_DRef.AxisNumber].ProfileVelocity

{$IFDEF MoreThan3Axes}
      else if n=4 then
        ht_DRef.Value:=T4[ht_DRef.AxisNumber].ProfileVelocity

      else if n=5 then
        ht_DRef.Value:=T5[ht_DRef.AxisNumber].ProfileVelocity

      else if n=6 then
        ht_DRef.Value:=T6[ht_DRef.AxisNumber].ProfileVelocity
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else
      GrammarError;
    end

  else
    GrammarError;
  end;
TRUE
TUserProcedure
0 {reference}
FALSE
24
Procedure bk_sm;

  var NextChar:integer;
  var Value:longint;

  begin
  NextChar:=StringAt(InspectToken.Value,2);
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then
    begin
    if NextChar=AsciiCode.BigS then {sms}
      begin
      Value:=NextLong;
      SetMicrostepsPerStep(Axis[ht_DRef.AxisNumber],Value);
      ht_DRef.Value:=Value;
      end
    else
      GrammarError;
    end
  else
    GrammarError;
  end;

