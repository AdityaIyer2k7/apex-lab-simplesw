98
Procedure bk_sp;

  var NextChar:integer;
  var n:integer;
  var Valid:boolean;
  var Param:longint;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);
  if ht_DRef.AxisTokenKind=tk_T1Axis then
    begin
    if NextChar=AsciiCode.BigD then
      begin {SPD}
      try
        begin
        Axis[ht_DRef.AxisNumber].SetSpeed(NextSingleAssignmentPermitted)
        end
      recover
        ConfirmNoExpression;
      ht_DRef.Value:=Axis[ht_DRef.AxisNumber].Speed
      end
    else
      GrammarError;
    end

  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);
    if NextChar=AsciiCode.BigD then
      begin
      if n=2 then
        begin
        try
          T2[ht_DRef.AxisNumber].SetSpeed(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T2[ht_DRef.AxisNumber].Speed
        end

      else if n=3 then
        begin
        try
          T3[ht_DRef.AxisNumber].SetSpeed(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T3[ht_DRef.AxisNumber].Speed
        end
{$IFDEF MoreThan3Axes}
      else if n=4 then
        begin
        try
          T4[ht_DRef.AxisNumber].SetSpeed(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T4[ht_DRef.AxisNumber].Speed
        end

      else if n=5 then
        begin
        try
          T5[ht_DRef.AxisNumber].SetSpeed(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T5[ht_DRef.AxisNumber].Speed
        end

      else if n=6 then
        begin
        try
          T6[ht_DRef.AxisNumber].SetSpeed(NextSingleAssignmentPermitted)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T6[ht_DRef.AxisNumber].Speed
        end
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else
      GrammarError;
    end

  else
    begin
    if NextChar=AsciiCode.BigC then
      ht_DRef.Value:=SampleCounter

    else if NextChar=AsciiCode.BigR then
      begin
      try
        SetSampleRate(NextLong)
      recover
        ConfirmNoExpression;
      ht_DRef.Value:=SampleRate
      end
    end;
  end;
TRUE
