103
procedure MonitorCommPort;

  var C:integer;
  var Response:Double;
  var TimeAnchor:longint;
  const PrompterCharacter=62;
  var Echo:boolean;
  var Accumulator:string[100];
  var Index:longint;

  begin
  Echo:=false;
  Index:=0;
  try
  begin
  while true do
    begin
    yield;
    if Comm.CharacterPresent then
      begin
      C:=Comm.GetCharacter;
      if C=13 then
        begin
        StringAtPut(Accumulator,Index,0);
        if Echo then
          begin
          Comm.SendCharacter(C);
          Comm.SendCharacter(10);
          end;
        try
          begin
          if Accumulator='' then
            Response:=0
          else
            begin
            TimeAnchor:=TimeRemaining;
            Response:=InterpretCommand(Accumulator);
            InterpreterElapsedTime:=TimeAnchor-TimeRemaining;
            end;
          Comm.SendCharacter(48); {0}
          Comm.SendCharacter(32);
          DoubleToString(Response,3,NumberString);
          Comm.SendString(NumberString);
          Comm.SendCharacter(32);
          Comm.SendCharacter(StringAt('>',0));
          end
        recover
          begin
          LongintToNumberString(EscapeCode);
          Comm.SendString(NumberString);
          Comm.SendCharacter(32);
          Comm.SendCharacter(StringAt('>',0));

          {Although this looks like a good idea, creating a different error response creates more confusion than value}

          {if EscapeCode=Error.Grammar then
            begin
            Comm.SendCharacter(32);
            LongintToNumberString(CommandIndex);
            Comm.SendString(NumberString);
            end;}
          end;
        if Echo then
          begin
          Comm.SendCharacter(13);
          Comm.SendCharacter(10);
          end;
        Index:=0;
        end
      else if C=8 then
        begin
        Index:=Index-1;
        if Index >= 0 then
          begin
          if Echo then
            begin
            Comm.SendCharacter(8);
            Comm.SendCharacter(32);
            Comm.SendCharacter(8);
            end;
          end
        else
          Index:=0;
        end
      else if C=10 then
        begin
        {ignore incoming line feeds}
        end
      else
        begin
        StringAtPut(Accumulator,Index,C);
        if Echo then
          Comm.SendCharacter(C);
        Index:=Index+1;
        end;
      end;
    end;
  end
  recover
    begin
    {silent shutdown when no hardware present}
    end;
  end;
TRUE
