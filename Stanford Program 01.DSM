0 {reference}
FALSE
8
Procedure ClearFifo;
  begin 
  Server.MemReadbyte($4006A004); {read s1 status register}
  Server.MemReadByte($4006A007); {read data value to clear overrun bit}
  Server.MemWriteByte($4006A011,$C0); {flush fifos to realign pointers}
  Head:=0;
  Tail:=0;
  end;
TRUE
TUserProcedure
15 {reference}
TRUE
44
Procedure Initialize_With_Baud_Rate(ListShowBaudRate:longint {9600 19200 38400 57600 115200});
  begin
  {set to 9600 baud}
  Server.MemWriteByte($4006A003,0); {disable uart transmit and receive}
  if ListShowBaudRate=9600 then
    begin
    Server.MemWriteByte($4006A000,2);
    Server.MemWriteByte($4006A001,$8B);
    Server.MemWriteByte($4006A00A,(Server.MemReadByte($4006A00A) and $E0) or 1);
    end
  else if ListShowBaudRate=19200 then
    begin
    Server.MemWriteByte($4006A000,1);
    Server.MemWriteByte($4006A001,$45);
    Server.MemWriteByte($4006A00A,(Server.MemReadByte($4006A00A) and $E0) or 17);
    end
  else if ListShowBaudRate=38400 then
    begin
    Server.MemWriteByte($4006A000,0);
    Server.MemWriteByte($4006A001,$A2);
    Server.MemWriteByte($4006A00A,(Server.MemReadByte($4006A00A) and $E0) or 24);
    end
  else if ListShowBaudRate=57600 then
    begin
    Server.MemWriteByte($4006A000,0);
    Server.MemWriteByte($4006A001,$6C);
    Server.MemWriteByte($4006A00A,(Server.MemReadByte($4006A00A) and $E0) or 16);
    end
  else if ListShowBaudRate=115200 then
    begin
    Server.MemWriteByte($4006A000,0);
    Server.MemWriteByte($4006A001,$36);
    Server.MemWriteByte($4006A00A,(Server.MemReadByte($4006A00A) and $E0) or 8);
    end
  else
    Escape(ParameterOutOfRangeEscapeCode);
  Server.MemWriteByte($4006A003,$0C);{reenable uart after adjustments}

  RS232SetEnable(on);
  TurnYellowLed(off);
  ClearFifo;
  BeginTask(TaskAddr(MaintainFifo));
  end;

TRUE
TUserProcedure
0 {reference}
FALSE
25
Procedure MaintainFifo;

  var Counter:longint;

  begin
  DebugCounter:=0;
  Counter:=0;
  ClearFifo;
  while true do
    begin
    DebugCounter:=DebugCounter+1;
    while HardwareCharacterPresent do
      begin
      Fifo[Head]:=HardwareGetCharacter;
      Head:=(Head+1) and FifoSize;
      Counter:=Counter+1;
      if Counter > 20 then
        begin
        Counter:=0;
        yield;
        end;
      end;
    yield;
    end;
  end;
TRUE
