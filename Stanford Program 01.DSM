Procedure bk_ma;

  var NextChar:integer;
  var n:integer;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);    
    if NextChar=AsciiCode.BigC then
      begin
      if n=2 then
        begin
        T2[ht_DRef.AxisNumber].BeginMoveAlongCurve;
        while not T2[ht_DRef.AxisNumber].MoveIsFinished do
          yield;
        end
      else if n=3 then
        begin
        T3[ht_Dref.AxisNumber].BeginMoveAlongCurve
        while not T3[ht_DRef.AxisNumber].MoveIsFinished do
          yield;
        end

{$IFDEF MoreThan3Axes}
      else if n=4 then
        begin
        T4[ht_Dref.AxisNumber].BeginMoveAlongCurve
        while not T4[ht_DRef.AxisNumber].MoveIsFinished do
          yield;
        end
      else if n=5 then
        begin
        T5[ht_DRef.AxisNumber].BeginMoveAlongCurve
        while not T5[ht_DRef.AxisNumber].MoveIsFinished do
          yield;
        end
      else if n=6 then
        begin
        T6[ht_Dref.AxisNumber].BeginMoveAlongCurve
        while not T6[ht_DRef.AxisNumber].MoveIsFinished do
          yield;
        end
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else
      GrammarError;
    end

  else
    GrammarError;
  end;
