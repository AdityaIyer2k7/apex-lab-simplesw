152
Procedure GetNextToken(var Source:string; var scanner:integer);
{--------------------------------------------------------------------------------}
{ This routine seperates tokens in the command line and identifies multiple      }
{ character groups into abstract tokens                                          }
{________________________________________________________________________________}

  var TokenScanner:integer;
  var NextChar:integer;
  var ScanDone:boolean;
  var UpperChar:integer;

  begin
  SkipOverWhiteSpace(Source,scanner);

  NextChar:=StringAt(source,scanner);   

  if NextChar=AsciiCode.PlusSign then
    begin
    InspectToken.Kind:=tk_PlusOp;
    scanner:=scanner+1;
    exit;
    end;

  if NextChar=AsciiCode.MultiplySign then
    begin
    InspectToken.Kind:=tk_MultiplyOp;
    scanner:=scanner+1;
    exit;
    end;

  if IsPartOfANumber(NextChar) then
    begin
    TokenScanner:=0;
    While IsPartOfANumber(NextChar) do
      begin
      StringAtPut(InspectToken.Value,TokenScanner,NextChar);
      scanner:=scanner+1;
      TokenScanner:=TokenScanner+1;
      NextChar:=StringAt(Source,scanner);
      end;
    StringAtPut(InspectToken.Value,TokenScanner,0);
    InspectToken.Kind:=tk_Literal;
    exit;    
    end

  if NextChar=AsciiCode.Colon then
    begin
    scanner:=scanner+1;
    NextChar:=StringAt(Source,scanner);
    if NextChar=AsciiCode.EqualsSign then
      begin
      scanner:=scanner+1;
      InspectToken.Kind:=tk_Assignment;
      exit;
      end
    else
      ScanningError(scanner);
    end;
      
  if NextChar=AsciiCode.LessThanSign then
    begin
    scanner:=scanner+1;
    NextChar:=StringAt(Source,scanner);
    if NextChar=AsciiCode.EqualsSign then
      begin
      scanner:=scanner+1;
      InspectToken.Kind:=tk_LessThanOrEqualTo;
      exit;
      end
    else if NextChar=AsciiCode.GreaterThanSign then
      begin
      scanner:=scanner+1;
      InspectToken.Kind:=tk_NotEqualTo;
      exit;
      end
    else
      begin
      InspectToken.Kind:=tk_LessThan;
      exit;
      end;
    end;

  if NextChar=AsciiCode.GreaterThanSign then
    begin
    scanner:=scanner+1;
    NextChar:=StringAt(Source,scanner);
    if NextChar=AsciiCode.EqualsSign then
      begin
      scanner:=scanner+1;
      InspectToken.Kind:=tk_GreaterThanOrEqualTo;
      exit;
      end
    else
      begin
      InspectToken.Kind:=tk_GreaterThan;
      exit;
      end;
    end;

  if IsPartOfAWord(NextChar,UpperChar) then
    begin    
    TokenScanner:=0;    
    InspectToken.Kind:=tk_Word; {possibly}
    While IsPartOfAWord(NextChar,UpperChar) do      
      begin
      StringAtPut(InspectToken.Value,TokenScanner,UpperChar);
      if TokenScanner=0 then
        begin
        if UpperChar=AsciiCode.BigA then
          InspectToken.Kind:=tk_T1Axis {possibly}
        else if UpperChar=AsciiCode.BigC then
          InspectToken.Kind:=tk_TNAxis;
        end;
      TokenScanner:=TokenScanner+1;
      scanner:=scanner+1;
      NextChar:=StringAt(Source,scanner);
      end;
    StringAtPut(InspectToken.Value,TokenScanner,0);    
    if TokenScanner <> 1 then
      InspectToken.Kind:=tk_Word;
    exit;
    end;

  if NextChar=AsciiCode.LeftParen then
    begin
    scanner:=scanner+1;
    InspectToken.Kind:=tk_LeftParen;
    exit;
    end;

  if NextChar=AsciiCode.RightParen then
    begin
    scanner:=scanner+1;
    InspectToken.Kind:=tk_RightParen;
    exit;
    end;

  if NextChar=0 then
    begin
    InspectToken.Kind:=tk_nil;
    exit;
    end;

  if NextChar=AsciiCode.Period then
    begin
    InspectToken.Kind:=tk_Period;
    exit;
    end;

  ScanningError(scanner);  
  end;

TRUE
TUserProcedure
