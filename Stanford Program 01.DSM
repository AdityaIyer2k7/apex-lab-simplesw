  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);
    ht_DRef.Value:=n;
    if NextChar=AsciiCode.BigP then
      begin
      if n=2 then
        begin
        try
          T2[ht_DRef.AxisNumber].SetCommandedPosition(
            NextDouble,
            NextDouble)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T2[ht_DRef.AxisNumber].CommandedPosition;
        end

      else if n=3 then
        begin
        try
          T3[ht_DRef.AxisNumber].SetCommandedPosition(
            NextDouble,
            NextDouble,
            NextDouble)
        recover
          ConfirmNoExpression;
        ht_DRef.Value:=T3[ht_DRef.AxisNumber].CommandedPosition;
