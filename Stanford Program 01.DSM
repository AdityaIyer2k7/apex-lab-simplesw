5
Procedure ConfirmNoExpression;
  begin
  if EscapeCode <> Error.TooFewParameters then
    Escape(EscapeCode);
  end;
TRUE
TUserProcedure
0 {reference}
FALSE
91
procedure Expression(var Answer:double);

  var NextAnswer:double;
  var Ref:TDRef;
  var Valid:boolean;

  begin
  Ref.Init;   
  if InspectToken.Kind=tk_Nil then    
    Escape(Error.TooFewParameters)

  else if InspectToken.Kind=tk_Literal then
    begin
    Answer:=DoubleInString(InspectToken.Value);
    Match(tk_Literal);        
    end

  else if InspectToken.Kind=tk_Word then
    begin
    if (InspectToken.Value='ON')
    or (InspectToken.Value='HI') then
      begin
      Answer:=1
      Match(tk_Word);
      end
    else if (InspectToken.Value='OFF')
    or (InspectToken.Value='LOW') then
      begin
      Answer:=0
      Match(tk_Word);
      end
    else if InspectToken.Value='STE' then      
      begin
      Answer:=StepperMotor
      Match(tk_Word);
      end
    else if InspectToken.Value='SRV' then
      begin
      Answer:=ServoMotor;
      Match(tk_Word);
      end
    else      
      Answer:=PerformHashFunction(Ref);               
    end

  else if InspectToken.Kind=tk_T1Axis then
    begin
    Match(tk_T1Axis);
    Ref.AxisTokenKind:=tk_T1Axis;
    Ref.AxisNumber:=LongintConfineBetween(ArrayIndexExpression,1,16,Error.AxisNumberOutOfBounds);    
    if InspectToken.Kind=tk_Word then
      Answer:=PerformHashFunction(Ref);    
    end

  else if InspectToken.Kind=tk_TnAxis then
    begin
    Match(tk_TnAxis);
    Ref.AxisTokenKind:=tk_TnAxis;
    Ref.AxisNumber:=LongintConfineBetween(ArrayIndexExpression,1,MaxGroupNumber,Error.GroupNumberOutOfBounds);    
    if InspectToken.Kind=tk_Word then
      Answer:=PerformHashFunction(Ref);    
    end

  else if InspectToken.Kind=tk_LeftParen then
    begin
    Match(tk_LeftParen);
    Expression(Answer);
    Match(tk_RightParen);    
    end
  
  else
    GrammarError;

  if InspectToken.IsAMathOperator then
    begin    
    if InspectToken.Kind=tk_PlusOp then      
      begin      
      Match(tk_PlusOp)     
      Expression(NextAnswer);                   
      Answer:=Answer+NextAnswer;
      end
    else if InspectToken.Kind=tk_MultiplyOp then      
      begin      
      Match(tk_MultiplyOp)     
      Expression(NextAnswer);                   
      Answer:=Answer*NextAnswer;
      end
    else
      Escape(Error.TooFewParameters);
    end  
  end;
TRUE
TUserProcedure
0 {reference}
FALSE
4
Procedure GrammarError;
  begin  
  Escape(Error.Grammar);
  end;
TRUE
TUserProcedure
17 {reference}
TRUE
144
Procedure Initialize;

  var scanner:integer;

  begin
  Comm.Set_Communication_Properties;
  ResetAllocation;
  for scanner:=1 to MaxUserTasks do
    UserTask[scanner]:=TaskAddr(NopTask);
  yield;

  for scanner:= 1 to MaxNamedProcedures do
    begin
    yield;
    ProcedureName[scanner]:='';
    end;

  for scanner:=0 to 676 do
    begin
    HashProcedureArray[scanner]:=TaskAddr(PerformIllegalCommandEscape);
    if (scanner and 15)=0 then
      yield;
    end;

  for scanner:=1 to MaxUserLongints do
    begin
    UserLongint[scanner]:=0;
    yield;
    end;

  for scanner:=1 to MaxUserNumbers do
    begin
    UserNumber[scanner]:=0;
    yield;
    end;

  for scanner:=1 to MaxUserBooleans do
    begin
    UserBoolean[scanner]:=false;
    yield;
    end;

  HashProcedureArray[HashIndexOfString('AB')]:=TaskAddr(bk_ab);
  HashProcedureArray[HashIndexOfString('AC')]:=TaskAddr(bk_ac);
  HashProcedureArray[HashIndexOfString('AI')]:=TaskAddr(bk_ai);
  HashProcedureArray[HashIndexOfString('AL')]:=TaskAddr(bk_al);
  HashProcedureArray[HashIndexOfString('AM')]:=TaskAddr(bk_am);
  HashProcedureArray[HashIndexOfString('AN')]:=TaskAddr(bk_an);
  HashProcedureArray[HashIndexOfString('AR')]:=TaskAddr(bk_ar);
  HashProcedureArray[HashIndexOfString('AU')]:=TaskAddr(bk_au);
  HashProcedureArray[HashIndexOfString('AX')]:=TaskAddr(bk_ax);
  yield;
  HashProcedureArray[HashIndexOfString('BM')]:=TaskAddr(bk_bm);
  HashProcedureArray[HashIndexOfString('BN')]:=TaskAddr(bk_bn);
  HashProcedureArray[HashIndexOfString('BS')]:=TaskAddr(bk_bs);
  HashProcedureArray[HashIndexOfString('BU')]:=TaskAddr(bk_bu);
  yield;
  HashProcedureArray[HashIndexOfString('CA')]:=TaskAddr(bk_ca);
  HashProcedureArray[HashIndexOfString('CH')]:=TaskAddr(bk_ch);
  HashProcedureArray[HashIndexOfString('CI')]:=TaskAddr(bk_ci);
  HashProcedureArray[HashIndexOfString('CL')]:=TaskAddr(bk_cl);
  HashProcedureArray[HashIndexOfString('CO')]:=TaskAddr(bk_co);
  HashProcedureArray[HashIndexOfString('CP')]:=TaskAddr(bk_cp);
  yield;
  HashProcedureArray[HashIndexOfString('DC')]:=TaskAddr(bk_dc);
  HashProcedureArray[HashIndexOfString('DE')]:=TaskAddr(bk_de);
  HashProcedureArray[HashIndexOfString('DL')]:=TaskAddr(bk_dl);
  HashProcedureArray[HashIndexOfString('DS')]:=TaskAddr(bk_ds);
  yield;
  HashProcedureArray[HashIndexOfString('EI')]:=TaskAddr(bk_ei);
  HashProcedureArray[HashIndexOfString('EN')]:=TaskAddr(bk_en);
  HashProcedureArray[HashIndexOfString('ER')]:=TaskAddr(bk_er);
  yield;
  HashProcedureArray[HashIndexOfString('GA')]:=TaskAddr(bk_ga);
  yield;
  HashProcedureArray[HashIndexOfString('IN')]:=TaskAddr(bk_in);  
  HashProcedureArray[HashIndexOfString('IS')]:=TaskAddr(bk_is);  
  HashProcedureArray[HashIndexOfString('IT')]:=TaskAddr(bk_it);  
  yield;
  HashProcedureArray[HashIndexOfString('JO')]:=TaskAddr(bk_jo);  
  yield;
  HashProcedureArray[HashIndexOfString('LI')]:=TaskAddr(bk_li);  
  HashProcedureArray[HashIndexOfString('LN')]:=TaskAddr(bk_ln);  
  yield;
  HashProcedureArray[HashIndexOfString('MA')]:=TaskAddr(bk_ma);  
  HashProcedureArray[HashIndexOfString('MI')]:=TaskAddr(bk_mi);  
  HashProcedureArray[HashIndexOfString('MT')]:=TaskAddr(bk_mt);  
  HashProcedureArray[HashIndexOfString('MV')]:=TaskAddr(bk_mv);  
  yield;
  HashProcedureArray[HashIndexOfString('NL')]:=TaskAddr(bk_nl);  
  yield;
  HashProcedureArray[HashIndexOfString('PF')]:=TaskAddr(bk_pf);
  HashProcedureArray[HashIndexOfString('PL')]:=TaskAddr(bk_pl);
  HashProcedureArray[HashIndexOfString('PU')]:=TaskAddr(bk_pu);
  yield;
  HashProcedureArray[HashIndexOfString('RS')]:=TaskAddr(bk_rs);  
  HashProcedureArray[HashIndexOfString('RU')]:=TaskAddr(bk_ru);  
  HashProcedureArray[HashIndexOfString('RW')]:=TaskAddr(bk_rw);  
  yield;
  HashProcedureArray[HashIndexOfString('SC')]:=TaskAddr(bk_sc);  
  HashProcedureArray[HashIndexOfString('SM')]:=TaskAddr(bk_sm);
  HashProcedureArray[HashIndexOfString('SO')]:=TaskAddr(bk_so);
  HashProcedureArray[HashIndexOfString('SP')]:=TaskAddr(bk_sp);
  HashProcedureArray[HashIndexOfString('ST')]:=TaskAddr(bk_st);  
  HashProcedureArray[HashIndexOfString('SU')]:=TaskAddr(bk_su);  
  yield;
  HashProcedureArray[HashIndexOfString('TR')]:=TaskAddr(bk_tr);  
  yield;
  HashProcedureArray[HashIndexOfString('UH')]:=TaskAddr(bk_uh);  
  HashProcedureArray[HashIndexOfString('US')]:=TaskAddr(bk_us);  
  HashProcedureArray[HashIndexOfString('UT')]:=TaskAddr(bk_ut);  
  yield;
  HashProcedureArray[HashIndexOfString('WH')]:=TaskAddr(bk_wh);  
  yield;
  HashProcedureArray[HashIndexOfString('ZE')]:=TaskAddr(bk_ze);  

  HashProcedureArray[HashIndexOfString('HM')]:=TaskAddr(bk_hm);
  
  try
    ResetWatchdog
  recover
    begin
    {do not stop even if estopped}
    end;

  UserTask[1]:=TaskAddr(UserTask1);
  UserTask[2]:=TaskAddr(UserTask2);
  UserTask[3]:=TaskAddr(UserTask3);
  UserTask[4]:=TaskAddr(UserTask4);
  UserTask[5]:=TaskAddr(UserTask5);
  UserTask[6]:=TaskAddr(UserTask6);
  UserTask[7]:=TaskAddr(UserTask7);
  UserTask[8]:=TaskAddr(UserTask8);
  UserTask[9]:=TaskAddr(UserTask9);
  UserTask[10]:=TaskAddr(UserTask10);
  UserTask[11]:=TaskAddr(UserTask11);
  UserTask[12]:=TaskAddr(UserTask12);
  UserTask[13]:=TaskAddr(UserTask13);
  UserTask[14]:=TaskAddr(UserTask14);
  UserTask[15]:=TaskAddr(UserTask15);
  UserTask[16]:=TaskAddr(UserTask16);

  BeginTask(TaskAddr(MonitorCommPort));
  end; 
