17
Procedure SkipOverWhiteSpace(var Source:string; var scanner:integer);
{--------------------------------------------------------------------------------}

  var ScanDone:boolean;
  var NextChar:integer;

  begin
  ScanDone:=false;
  repeat
    NextChar:=StringAt(Source,scanner);
    if (NextChar=32)
    or (NextChar=44) then
      scanner:=scanner+1
    else
      ScanDone:=true;
  until ScanDone;  
  end;
TRUE
