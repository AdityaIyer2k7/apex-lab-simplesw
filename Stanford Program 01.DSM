const tk_nil                 = 0;
const tk_word                = 1; {general alpha that's not a predefined object type}
const tk_T1Axis              = 2; {an isolated "A"}
const tk_TNAxis              = 3; {an isolated "G"}
const tk_Assignment          = 4;
const tk_Literal             = 5;
const tk_LessThanOrEqualTo   = 6;
const tk_NotEqualTo          = 7;
const tk_LessThan            = 8;
const tk_GreaterThanOrEqualTo= 9;
const tk_GreaterThan         =10;
const tk_PlusOp              =11;
const tk_MultiplyOp          =12;
const tk_LeftParen           =13;
const tk_RightParen          =14;
const tk_Period              =15;

Type TToken=object
  Value:String[127];
  Kind:integer;    

  function IsAMathOperator:boolean;
    begin
    IsAMathOperator:=false;
    if Kind=tk_PlusOp then
      IsAMathOperator:=true
    else if Kind=tk_MultiplyOp then
      IsAMathOperator:=true;
    end;
  end;

