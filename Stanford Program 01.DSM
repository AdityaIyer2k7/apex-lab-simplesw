17
Function IsPartOfAWord(CharOrd:integer; var UpperCaseChar:integer):boolean;
{--------------------------------------------------------------------------------}

  begin
  IsPartOfAWord:=true;
  UpperCaseChar:=CharOrd;
  if (CharOrd >= AsciiCode.SmallA)
  and (CharOrd <= AsciiCode.SmallZ) then
    begin
    UpperCaseChar:=CharOrd+AsciiCode.SmallAToBigAOffset;
    exit;
    end;
  if (CharOrd >= AsciiCode.BigA)
  and (CharOrd <= AsciiCode.BigZ) then
    exit;
  IsPartOfAWord:=false;
  end;
