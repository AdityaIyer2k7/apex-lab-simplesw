76
Procedure bk_mv;

  var NextChar:integer;
  var n:integer;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if ht_DRef.AxisTokenKind=tk_T1Axis then   
    begin
    if NextChar=AsciiCode.BigB then {bmb}
      Axis[ht_DRef.AxisNumber].MoveBy(NextDouble)

    else if NextChar=AsciiCode.BigT then {bmt}
      Axis[ht_DRef.AxisNumber].MoveTo(NextDouble)
    end

  else if ht_DRef.AxisTokenKind=tk_TNAxis then
    begin
    n:=GroupDimension(ht_DRef.AxisNumber);    
    if NextChar=AsciiCode.BigB then {relative move}
      begin
      if n=2 then
        T2[ht_DRef.AxisNumber].MoveBy(
          NextDouble,NextDouble)
      else if n=3 then
        T3[ht_Dref.AxisNumber].MoveBy(
          NextDouble,NextDouble,NextDouble)
{$IFDEF MoreThan3Axes}
      else if n=4 then
        T4[ht_Dref.AxisNumber].MoveBy(
          NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=5 then
        T5[ht_DRef.AxisNumber].MoveBy(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=6 then
        begin
        T6[ht_Dref.AxisNumber].BeginMoveBy(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
        while not T6[ht_DRef.AxisNumber].MoveIsFinished do
          yield;
        end
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else if NextChar=AsciiCode.BigT then {absolute move}
      begin
      if n=2 then
        T2[ht_DRef.AxisNumber].MoveTo(
          NextDouble,NextDouble)
      else if n=3 then
        T3[ht_Dref.AxisNumber].MoveTo(
          NextDouble,NextDouble,NextDouble)
{$IFDEF MoreThan3Axes}
      else if n=4 then
        T4[ht_Dref.AxisNumber].MoveTo(
          NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=5 then
        T5[ht_DRef.AxisNumber].MoveTo(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
      else if n=6 then
        T6[ht_Dref.AxisNumber].MoveTo(
          NextDouble,NextDouble,NextDouble,NextDouble,NextDouble,NextDouble)
{$ENDIF}
      else
        Escape(Error.IllegalDimension);
      end
    else
      GrammarError;
    end

  else
    GrammarError;
  end;
TRUE
