14
Function IsPartOfANumber(CharOrd:integer):boolean;
{--------------------------------------------------------------------------------}

  begin
  IsPartOfANumber:=true;
  if CharOrd=AsciiCode.MinusSign then
    exit; 
  if CharOrd=AsciiCode.Period then
    exit;
  if (CharOrd >= AsciiCode.Zero)
  and (CharOrd <= AsciiCode.Nine) then
    exit;
  IsPartOfANumber:=false;
  end;
TRUE
