      recover
        ConfirmNoExpression;
      ht_DRef.Value:=Value;
      end
    else if NextChar=AsciiCode.BigT then
      begin {SCT}
      try
        begin
        NextState:=NextBoolean;
        Axis[ht_DRef.AxisNumber].SetCaptureTrip(NextState);
        end
      recover
        ConfirmNoExpression;
      ht_DRef.Value:=BooleanToInteger(NextState);
      end
    else
      GrammarError;
    end
  else
    GrammarError;
  end;
