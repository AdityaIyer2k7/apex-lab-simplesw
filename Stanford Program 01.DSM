90
Procedure bk_in;

  var NextChar:integer;
  var n:integer;
  var Dimension:integer;
  var M:array[1..6] of integer;
  var M1,M2,M3,M4,M5,M6:integer;

  begin
  NextChar:=StringAt(InspectToken.Value,2); {third character}
  Match(tk_Word);

  if NextChar=AsciiCode.BigI then
    begin
    if ht_DRef.AxisTokenKind <> tk_TNAxis then
      Escape(Error.CoordinatedGroupRequired);    

    Dimension:=0;
    while InspectToken.Kind=tk_Literal do
      begin
      Dimension:=Dimension+1;
      if Dimension > 6 then
        Escape(Error.TooManyParameters);
      M[Dimension]:=NextLong;
      end;

    if Dimension < 2 then
      Escape(Error.TooFewParameters);

    ht_DRef.Value:=Dimension;
    GroupDimensionArray[ht_DRef.AxisNumber]:=Dimension;

    M1:=M[1]; {nested array references not allowed}
    M2:=M[2];
    M3:=M[3];
    M4:=M[4];
    M5:=M[5];
    M6:=M[6];

    if Dimension=2 then
      begin
      T2[ht_DRef.AxisNumber].Init(Axis[M1],Axis[M2]);
      T2[ht_DRef.AxisNumber].SetCountsPerUserUnit(MaxDouble(Axis[M1].CountsPerUserUnit,Axis[M2].CountsPerUserUnit));
      end
    else if Dimension=3 then
      begin
      T3[ht_DRef.AxisNumber].Init(Axis[M1],Axis[M2],Axis[M3]);
      T3[ht_DRef.AxisNumber].SetCountsPerUserUnit(
        MaxDouble(MaxDouble(Axis[M1].CountsPerUserUnit,Axis[M2].CountsPerUserUnit),Axis[M3].CountsPerUserUnit));
      end
{$IFDEF MoreThan3Axes}
    else if Dimension=4 then
      begin
      T4[ht_DRef.AxisNumber].Init(Axis[M1],Axis[M2],Axis[M3],Axis[M4]);
      T4[ht_DRef.AxisNumber].SetCountsPerUserUnit(
        MaxDouble(MaxDouble(
          MaxDouble(Axis[M1].CountsPerUserUnit,Axis[M2].CountsPerUserUnit),Axis[M3].CountsPerUserUnit),Axis[M4].CountsPerUserUnit));
      end

    else if Dimension=5 then
      begin
      T5[ht_DRef.AxisNumber].init(Axis[M1],Axis[M2],Axis[M3],Axis[M4],Axis[M5])
      T5[ht_DRef.AxisNumber].SetCountsPerUserUnit(
        MaxDouble(MaxDouble(MaxDouble(MaxDouble(
          Axis[M1].CountsPerUserUnit,Axis[M2].CountsPerUserUnit),Axis[M3].CountsPerUserUnit),Axis[M4].CountsPerUserUnit),Axis[M5].CountsPerUserUnit));
      end
    else if Dimension=6 then
      begin
      T6[ht_DRef.AxisNumber].init(Axis[M1],Axis[M2],Axis[M3],Axis[M4],Axis[M5],Axis[M6])
      T6[ht_DRef.AxisNumber].SetCountsPerUserUnit(
        MaxDouble(MaxDouble(MaxDouble(MaxDouble(MaxDouble(
          Axis[M1].CountsPerUserUnit,Axis[M2].CountsPerUserUnit),Axis[M3].CountsPerUserUnit),
          Axis[M4].CountsPerUserUnit),Axis[M5].CountsPerUserUnit),Axis[M6]].CountsPerUserUnit));
      end
{$ENDIF}
    else
      Escape(Error.Assertion);

    GroupInitialized[ht_Dref.AxisNumber]:=true;
    end

  else if NextChar=AsciiCode.BigB then
    ht_DRef.Value:=BooleanToInteger(
      InputBit(IntegerConfineBetween(
        NextLong,1,48,ParameterOutOfRangeEscapeCode)))

  else
    GrammarError;
 
  end;
TRUE
TUserProcedure
0 {reference}
FALSE
